{
  // Project-wide markdownlint configuration.
  //
  // Mirrors pdomain-ocr-synth — its spec/docs style is closest to this repo's
  // (long-form `specs/00-09` design docs with tables, fenced code, and
  // prose paragraphs that wrap at sentence boundaries).
  "config": {
    "default": true,
    "MD013": {
      "line_length": 120,
      "code_blocks": false,
      "tables": false,
      "headings": false,
      "strict": false
    },
    "MD022": false,
    "MD031": false,
    "MD040": false,
    "MD060": false
  },
  "ignores": [
    ".venv/**",
    "node_modules/**",
    "frontend/node_modules/**",
    "frontend/dist/**",
    "src/pdomain_prep_for_pgdp/static/**",
    ".pytest_cache/**",
    // Historical context — superseded by specs/00-09. Per CLAUDE.md
    // these are canonical and the proposal is reference-only.
    "specs/REFACTOR-PROPOSAL.md",
    // Plans inherit prose styles from upstream superpowers templates;
    // line-length and table-style differ across plans and shouldn't
    // gate commits.
    "docs/plans/**",
    // Archived plans and process docs — historical snapshots, not
    // authoritative. Frozen at the form they shipped in.
    "docs/archive/**",
    // Audit reports — generated reference dumps, not prose docs.
    // Long lines in finding descriptions are expected.
    "docs/audit/**"
  ]
}
